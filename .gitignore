# Terraform state files
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Terraform directories
.terraform/
.terraform.d/

# Local terraform variable files (override files)
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Environment files
.env
.env.local
.env.*.local

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# OS-specific files
.AppleDouble
.LSOverride
*.pem
*.key

# Crash dumps
crash.log
crash.*.log

# Backup files
*.backup
*.bak
*.backup.*

# Temporary files
*.tmp
tmp/
temp/

# Pre-reqs specific
pre_reqs/.terraform/
pre_reqs/.terraform.lock.hcl
pre_reqs/*.tfvars
pre_reqs/*.tfvars.json
!pre_reqs/terraform.tfvars.example

# Logs
*.log
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Node (if any frontend build tools)
node_modules/
dist/
build/

# IDE workspace settings
.vscode/settings.json
.idea/workspace.xml
.idea/tasks.xml

# Sensitive files
id_rsa
id_rsa.pub
known_hosts
